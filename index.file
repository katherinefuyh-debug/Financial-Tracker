<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Finance Hub</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --color-background-primary:#ffffff;
  --color-background-secondary:#f5f5f4;
  --color-background-tertiary:#eeece8;
  --color-background-info:#e6f1fb;
  --color-background-danger:#fcebeb;
  --color-background-warning:#faeeda;
  --color-background-success:#eaf3de;
  --color-text-primary:#1a1a18;
  --color-text-secondary:#5f5e5a;
  --color-text-tertiary:#888780;
  --color-text-info:#185fa5;
  --color-text-danger:#a32d2d;
  --color-text-warning:#854f0b;
  --color-text-success:#3b6d11;
  --color-border-tertiary:rgba(0,0,0,0.10);
  --color-border-secondary:rgba(0,0,0,0.20);
  --color-border-primary:rgba(0,0,0,0.30);
  --color-border-info:#85b7eb;
  --color-border-warning:#fac775;
  --color-border-success:#97c459;
  --color-border-danger:#f09595;
  --border-radius-md:8px;
  --border-radius-lg:12px;
  --font-sans:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
}
@media(prefers-color-scheme:dark){
  :root{
    --color-background-primary:#1c1c1a;
    --color-background-secondary:#272724;
    --color-background-tertiary:#2c2c2a;
    --color-background-info:#0c447c;
    --color-background-danger:#501313;
    --color-background-warning:#412402;
    --color-background-success:#173404;
    --color-text-primary:#f0ede6;
    --color-text-secondary:#b4b2a9;
    --color-text-tertiary:#888780;
    --color-text-info:#85b7eb;
    --color-text-danger:#f09595;
    --color-text-warning:#fac775;
    --color-text-success:#97c459;
    --color-border-tertiary:rgba(255,255,255,0.10);
    --color-border-secondary:rgba(255,255,255,0.20);
    --color-border-primary:rgba(255,255,255,0.30);
    --color-border-info:#0c447c;
    --color-border-warning:#633806;
    --color-border-success:#27500a;
    --color-border-danger:#791f1f;
  }
}
body{font-family:var(--font-sans);font-size:14px;color:var(--color-text-primary);background:var(--color-background-tertiary);min-height:100vh;padding:1.5rem 1rem;}
.container{max-width:580px;margin:0 auto;}
input,select,button{font-family:var(--font-sans);}
.tab-bar{display:flex;gap:3px;background:var(--color-background-secondary);border-radius:8px;padding:3px;margin-bottom:1.25rem;}
.tab{flex:1;text-align:center;padding:6px 2px;border-radius:6px;font-size:11px;cursor:pointer;color:var(--color-text-secondary);white-space:nowrap;}
.tab.active{background:var(--color-background-primary);border:0.5px solid var(--color-border-secondary);color:var(--color-text-primary);font-weight:500;}
.card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:12px;padding:1rem 1.25rem;margin-bottom:.75rem;}
.metrics{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-bottom:1rem;}
.mc{background:var(--color-background-secondary);border-radius:8px;padding:.75rem 1rem;}
.mc-l{font-size:11px;color:var(--color-text-secondary);margin-bottom:3px;}
.mc-v{font-size:18px;font-weight:500;}
.fl{font-size:13px;color:var(--color-text-secondary);margin-bottom:5px;}
.fi{width:100%;border:none;border-bottom:.5px solid var(--color-border-secondary);background:transparent;color:var(--color-text-primary);font-size:14px;padding:4px 0;outline:none;}
.frow{margin-bottom:11px;}
.btn-main{width:100%;padding:10px;font-size:14px;font-weight:500;cursor:pointer;border-radius:8px;background:var(--color-background-primary);color:var(--color-text-primary);border:.5px solid var(--color-border-secondary);}
.btn-main:hover{background:var(--color-background-secondary);}
.tx-item{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:.5px solid var(--color-border-tertiary);}
.tx-item:last-child{border-bottom:none;}
.tx-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.tx-name{flex:1;min-width:0;}
.tx-main{font-size:13px;color:var(--color-text-primary);}
.tx-sub{font-size:11px;color:var(--color-text-secondary);}
.tx-amt{font-size:13px;font-weight:500;white-space:nowrap;}
.del-btn{font-size:11px;color:var(--color-text-tertiary);cursor:pointer;padding:2px 6px;border-radius:4px;border:none;background:transparent;}
.del-btn:hover{color:var(--color-text-danger);}
.section-head{font-size:12px;color:var(--color-text-secondary);font-weight:500;margin:1rem 0 .5rem;letter-spacing:.04em;}
.urgbadge{font-size:10px;padding:1px 6px;border-radius:10px;background:var(--color-background-danger);color:var(--color-text-danger);}
.warnbadge{font-size:10px;padding:1px 6px;border-radius:10px;background:var(--color-background-warning);color:var(--color-text-warning);}
.okbadge{font-size:10px;padding:1px 6px;border-radius:10px;background:var(--color-background-success);color:var(--color-text-success);}
.strat-card{background:var(--color-background-primary);border:.5px solid var(--color-border-tertiary);border-radius:8px;padding:.75rem 1rem;margin-bottom:.5rem;display:flex;align-items:center;gap:10px;}
.rank-circle{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;flex-shrink:0;}
.empty{text-align:center;padding:2rem;color:var(--color-text-tertiary);font-size:13px;}
.sub-card{background:var(--color-background-primary);border:.5px solid var(--color-border-tertiary);border-radius:10px;padding:.875rem 1rem;margin-bottom:.5rem;}
.row{display:flex;align-items:center;gap:8px;}
.credit-bar-track{height:8px;background:var(--color-background-secondary);border-radius:4px;overflow:hidden;margin-top:6px;}
.credit-bar-fill{height:100%;border-radius:4px;transition:width .3s;}
</style>
</head>
<body>
<div class="container">

<div class="tab-bar">
  <div class="tab active" id="tab-dash" onclick="sw('dash')">总览</div>
  <div class="tab" id="tab-tx" onclick="sw('tx')">记账</div>
  <div class="tab" id="tab-transfer" onclick="sw('transfer')">转账</div>
  <div class="tab" id="tab-subs" onclick="sw('subs')">固定扣款</div>
  <div class="tab" id="tab-debt" onclick="sw('debt')">负债</div>
  <div class="tab" id="tab-accts" onclick="sw('accts')">账户</div>
</div>

<!-- DASHBOARD -->
<div id="panel-dash">
  <div class="metrics">
    <div class="mc"><div class="mc-l">净资产</div><div class="mc-v" id="d-net">$0</div></div>
    <div class="mc"><div class="mc-l">本月支出</div><div class="mc-v" style="color:var(--color-text-danger);" id="d-spent">$0</div></div>
    <div class="mc"><div class="mc-l">本月收入</div><div class="mc-v" style="color:var(--color-text-success);" id="d-income">$0</div></div>
  </div>
  <div id="d-upcoming"></div>
  <div id="d-subs-alert"></div>
  <div id="d-credit-section"></div>
  <div class="section-head">本月支出分类</div>
  <div class="card" style="margin-bottom:.75rem;">
    <div id="cat-legend" style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:10px;font-size:11px;color:var(--color-text-secondary);"></div>
    <div style="position:relative;width:100%;height:200px;"><canvas id="chart-cat"></canvas></div>
  </div>
  <div class="section-head">账户余额</div>
  <div id="d-accts-list"></div>
  <div class="section-head">最近记录</div>
  <div class="card"><div id="d-recent"></div></div>
</div>

<!-- TRANSACTIONS -->
<div id="panel-tx" style="display:none;">
  <div class="card">
    <div class="frow"><div class="fl">金额（$）</div>
      <input class="fi" id="tx-amt" type="number" placeholder="0.00" min="0" step="0.01" style="font-size:20px;font-weight:500;"/>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div class="frow"><div class="fl">类型</div>
        <select class="fi" id="tx-dir"><option value="out">支出</option><option value="in">收入</option></select>
      </div>
      <div class="frow"><div class="fl">账户</div><select class="fi" id="tx-acct"></select></div>
    </div>
    <div class="frow"><div class="fl">分类</div>
      <select class="fi" id="tx-cat">
        <option>餐饮</option><option>交通</option><option>购物</option><option>娱乐</option>
        <option>医疗</option><option>工资</option><option>投资</option><option>其他</option>
      </select>
    </div>
    <div class="frow"><div class="fl">备注（可选）</div><input class="fi" id="tx-note" type="text" placeholder="描述一下…"/></div>
    <div style="margin-top:.75rem;"><button class="btn-main" onclick="addTx()">记录</button></div>
  </div>
  <div class="section-head">本月明细</div>
  <div class="card"><div id="tx-list-el"></div></div>
</div>

<!-- TRANSFER -->
<div id="panel-transfer" style="display:none;">
  <div class="card">
    <div style="background:var(--color-background-secondary);border-radius:8px;padding:.75rem 1rem;margin-bottom:1rem;font-size:12px;color:var(--color-text-secondary);">
      储蓄卡 → 信用卡 = 还款，两边账户同时记录，信用卡余额自动减少。
    </div>
    <div class="frow"><div class="fl">金额（$）</div>
      <input class="fi" id="tr-amt" type="number" placeholder="0.00" min="0" step="0.01" style="font-size:20px;font-weight:500;"/>
    </div>
    <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:8px;align-items:end;">
      <div class="frow"><div class="fl">转出账户</div><select class="fi" id="tr-from"></select></div>
      <div style="padding-bottom:6px;color:var(--color-text-tertiary);font-size:18px;">→</div>
      <div class="frow"><div class="fl">转入账户</div><select class="fi" id="tr-to"></select></div>
    </div>
    <div class="frow"><div class="fl">备注（可选）</div><input class="fi" id="tr-note" type="text" placeholder="如：还款、零花钱…"/></div>
    <div style="margin-top:.75rem;"><button class="btn-main" onclick="doTransfer()">确认转账</button></div>
  </div>
  <div class="section-head">转账记录</div>
  <div class="card"><div id="tr-list-el"></div></div>
</div>

<!-- SUBSCRIPTIONS -->
<div id="panel-subs" style="display:none;">
  <div class="card">
    <div class="frow"><div class="fl">名称</div><input class="fi" id="sb-name" type="text" placeholder="如：Netflix、租金、手机账单"/></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div class="frow"><div class="fl">金额（$）</div><input class="fi" id="sb-amt" type="number" placeholder="0.00" min="0" step="0.01"/></div>
      <div class="frow"><div class="fl">扣款日（每月几号）</div><input class="fi" id="sb-day" type="number" placeholder="1–28" min="1" max="28"/></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div class="frow"><div class="fl">扣款账户</div><select class="fi" id="sb-acct"></select></div>
      <div class="frow"><div class="fl">分类</div>
        <select class="fi" id="sb-cat">
          <option>订阅/流媒体</option><option>租金</option><option>保险</option><option>手机/网络</option>
          <option>健身</option><option>软件</option><option>其他</option>
        </select>
      </div>
    </div>
    <div style="margin-top:.75rem;"><button class="btn-main" onclick="addSub()">添加</button></div>
  </div>
  <div id="subs-summary" style="margin-bottom:.75rem;"></div>
  <div class="section-head">本月固定扣款</div>
  <div id="subs-list-el"></div>
  <div style="margin-top:1rem;">
    <button class="btn-main" onclick="applyAllSubs()" style="border-color:var(--color-border-success);color:var(--color-text-success);">将本月未记录的扣款全部写入</button>
  </div>
</div>

<!-- DEBT -->
<div id="panel-debt" style="display:none;">
  <div class="metrics" style="grid-template-columns:repeat(2,minmax(0,1fr));">
    <div class="mc"><div class="mc-l">总负债</div><div class="mc-v" style="color:var(--color-text-danger);" id="dbt-total">$0</div></div>
    <div class="mc"><div class="mc-l">本月应还</div><div class="mc-v" style="color:var(--color-text-warning);" id="dbt-due">$0</div></div>
  </div>
  <div class="section-head">到期提醒</div>
  <div id="dbt-list-el"></div>
  <div class="section-head">还款策略</div>
  <div class="card" style="margin-bottom:.5rem;">
    <div class="fl" style="margin-bottom:8px;">每月额外可还（$）</div>
    <div class="row"><span style="color:var(--color-text-secondary);">$</span>
      <input class="fi" id="extra-pay" type="number" value="500" min="0" step="50" oninput="renderStrategy()" style="font-size:16px;font-weight:500;flex:1;"/>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:.75rem;">
      <div id="s-av" onclick="setStrat('avalanche')" style="border:2px solid var(--color-border-info);border-radius:8px;padding:.625rem;cursor:pointer;">
        <div style="font-size:12px;font-weight:500;color:var(--color-text-info);">雪崩法</div>
        <div style="font-size:11px;color:var(--color-text-secondary);margin-top:2px;">高利率优先，省利息</div>
      </div>
      <div id="s-sb" onclick="setStrat('snowball')" style="border:.5px solid var(--color-border-tertiary);border-radius:8px;padding:.625rem;cursor:pointer;">
        <div style="font-size:12px;font-weight:500;color:var(--color-text-primary);">雪球法</div>
        <div style="font-size:11px;color:var(--color-text-secondary);margin-top:2px;">小余额优先，有成就感</div>
      </div>
    </div>
  </div>
  <div id="strategy-list"></div>
</div>

<!-- ACCOUNTS -->
<div id="panel-accts" style="display:none;">
  <div class="card">
    <div class="frow"><div class="fl">账户名称</div><input class="fi" id="ac-name" type="text" placeholder="如：Chase Checking、Amex Blue"/></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div class="frow"><div class="fl">类型</div>
        <select class="fi" id="ac-type">
          <option value="checking">储蓄/支票账户</option>
          <option value="credit">信用卡</option>
          <option value="savings">储蓄账户</option>
          <option value="investment">投资账户</option>
          <option value="loan">贷款</option>
        </select>
      </div>
      <div class="frow"><div class="fl" id="ac-bal-label">当前余额（$）</div>
        <input class="fi" id="ac-bal" type="number" placeholder="0" min="0" step="0.01"/>
      </div>
    </div>
    <div id="ac-credit-fields" style="display:none;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="frow"><div class="fl">信用额度（$）</div><input class="fi" id="ac-limit" type="number" placeholder="如：5000" min="0"/></div>
        <div class="frow"><div class="fl">年利率（%）</div><input class="fi" id="ac-rate" type="number" placeholder="如：24.99" min="0" step="0.01"/></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="frow"><div class="fl">最低还款（$）</div><input class="fi" id="ac-minpay" type="number" placeholder="0" min="0"/></div>
        <div class="frow"><div class="fl">还款日（每月几号）</div><input class="fi" id="ac-dueday" type="number" placeholder="1–28" min="1" max="28"/></div>
      </div>
    </div>
    <div id="ac-loan-fields" style="display:none;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="frow"><div class="fl">年利率（%）</div><input class="fi" id="ac-loan-rate" type="number" placeholder="如：6.5" min="0" step="0.01"/></div>
        <div class="frow"><div class="fl">最低还款（$）</div><input class="fi" id="ac-loan-minpay" type="number" placeholder="0" min="0"/></div>
      </div>
      <div class="frow"><div class="fl">还款日（每月几号）</div><input class="fi" id="ac-loan-dueday" type="number" placeholder="1–28" min="1" max="28"/></div>
    </div>
    <div style="margin-top:.75rem;"><button class="btn-main" onclick="addAcct()">添加账户</button></div>
  </div>
  <div class="section-head">我的账户</div>
  <div id="accts-list-el"></div>

  <div class="section-head">数据备份</div>
  <div class="card">
    <div style="font-size:12px;color:var(--color-text-secondary);margin-bottom:12px;">导出后会下载一个 .json 文件，换设备或更新 HTML 时导入即可恢复所有数据。</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
      <button class="btn-main" onclick="exportData()" style="border-color:var(--color-border-info);color:var(--color-text-info);">导出数据</button>
      <button class="btn-main" onclick="document.getElementById('import-file').click()" style="border-color:var(--color-border-success);color:var(--color-text-success);">导入数据</button>
    </div>
    <input type="file" id="import-file" accept=".json" style="display:none;" onchange="importData(event)"/>
    <div id="import-status" style="margin-top:8px;font-size:12px;"></div>
  </div>
</div>

</div>

<script>
const COLORS=['#378ADD','#E24B4A','#7F77DD','#1D9E75','#EF9F27','#D4537E','#888780'];
const TYPE_LABEL={checking:'支票账户',credit:'信用卡',savings:'储蓄账户',investment:'投资账户',loan:'贷款'};
const CAT_COLORS={'餐饮':'#E24B4A','交通':'#378ADD','购物':'#D4537E','娱乐':'#7F77DD','医疗':'#1D9E75','工资':'#639922','投资':'#EF9F27','其他':'#888780','订阅/流媒体':'#5DCAA5','租金':'#F0997B','保险':'#AFA9EC','手机/网络':'#85B7EB','健身':'#C0DD97','软件':'#FAC775'};

let state={accounts:[],transactions:[],transfers:[],subscriptions:[]};
try{const s=localStorage.getItem('finhub_v4');if(s){state=JSON.parse(s);['accounts','transactions','transfers','subscriptions'].forEach(k=>{state[k]=state[k]||[];});}}catch(e){}

let stratMode='avalanche',currentTab='dash';
let catChart=null;

function save(){try{localStorage.setItem('finhub_v4',JSON.stringify(state));}catch(e){}}
function fmt(n){return '$'+(Math.abs(n)<0.005?'0.00':Math.abs(n).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}));}
function fmts(n){return(n<0?'-':'')+fmt(n);}
function color(i){return COLORS[i%COLORS.length];}
function acctColor(id){const i=state.accounts.findIndex(a=>a.id===id);return i>=0?color(i):'#888';}

function getDaysUntilDue(dd){
  const now=new Date(),d=now.getDate(),dim=new Date(now.getFullYear(),now.getMonth()+1,0).getDate();
  return dd>=d?dd-d:(dim-d)+dd;
}
function getMonthKey(){const n=new Date();return`${n.getFullYear()}-${n.getMonth()+1}`;}
function getMonthTxs(){
  const now=new Date();
  return state.transactions.filter(t=>{const d=new Date(t.date);return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();});
}
function acctBalance(id){
  const a=state.accounts.find(x=>x.id===id);if(!a)return 0;
  let bal=a.initBal;
  state.transactions.forEach(t=>{if(t.acctId===id)bal+=(t.dir==='in'?1:-1)*t.amt;});
  state.transfers.forEach(t=>{if(t.fromId===id)bal-=t.amt;if(t.toId===id)bal+=t.amt;});
  return bal;
}
function debtBalance(id){
  const a=state.accounts.find(x=>x.id===id);if(!a)return 0;
  let bal=a.initBal;
  state.transfers.forEach(t=>{if(t.toId===id)bal-=t.amt;});
  return Math.max(0,bal);
}
function creditUsed(a){
  let used=a.initBal;
  state.transfers.forEach(t=>{if(t.toId===a.id)used-=t.amt;});
  return Math.max(0,used);
}
function creditAvail(a){return Math.max(0,(a.creditLimit||0)-creditUsed(a));}

function isSubAppliedThisMonth(subId){
  const mk=getMonthKey();
  return state.transactions.some(t=>t.subId===subId&&t.monthKey===mk);
}
function applySubTx(sub){
  state.transactions.push({id:'t'+Date.now()+Math.random(),amt:sub.amt,acctId:sub.acctId,dir:'out',cat:sub.cat,note:sub.name,date:new Date().toISOString(),subId:sub.id,monthKey:getMonthKey(),auto:true});
  save();
}
function applyAllSubs(){
  let n=0;state.subscriptions.filter(s=>s.active!==false).forEach(sub=>{if(!isSubAppliedThisMonth(sub.id)){applySubTx(sub);n++;}});
  if(n>0){updateAll();alert('已写入 '+n+' 笔扣款');}else alert('本月所有扣款已记录');
}
function applySingleSub(id){const s=state.subscriptions.find(x=>x.id===id);if(!s||isSubAppliedThisMonth(id))return;applySubTx(s);updateAll();}

function populateSelects(){
  ['tx-acct','tr-from','tr-to','sb-acct'].forEach(sid=>{
    const el=document.getElementById(sid);if(!el)return;
    const prev=el.value;
    el.innerHTML=state.accounts.map(a=>'<option value="'+a.id+'">'+a.name+'</option>').join('');
    if(prev)el.value=prev;
  });
}

function renderCatChart(){
  const mTxs=getMonthTxs().filter(t=>t.dir==='out');
  const cats={};
  mTxs.forEach(t=>{cats[t.cat]=(cats[t.cat]||0)+t.amt;});
  const labels=Object.keys(cats);
  const vals=labels.map(k=>Math.round(cats[k]*100)/100);
  const total=vals.reduce((a,b)=>a+b,0);
  const bgColors=labels.map(l=>CAT_COLORS[l]||'#888780');
  const legendEl=document.getElementById('cat-legend');
  const wrapper=document.getElementById('chart-cat').parentElement;
  if(labels.length===0){
    legendEl.innerHTML='';
    if(catChart){catChart.destroy();catChart=null;}
    wrapper.innerHTML='<div class="empty" style="padding:1rem;">本月暂无支出记录</div>';
    return;
  }
  if(!document.getElementById('chart-cat')){
    wrapper.innerHTML='<canvas id="chart-cat"></canvas>';
  }
  legendEl.innerHTML=labels.map((l,i)=>{
    const pct=total>0?Math.round(vals[i]/total*100):0;
    return'<span style="display:flex;align-items:center;gap:4px;"><span style="width:10px;height:10px;border-radius:2px;background:'+bgColors[i]+';flex-shrink:0;"></span>'+l+' '+pct+'%</span>';
  }).join('');
  const canvas=document.getElementById('chart-cat');
  if(!canvas)return;
  if(catChart)catChart.destroy();
  catChart=new Chart(canvas,{
    type:'doughnut',
    data:{labels,datasets:[{data:vals,backgroundColor:bgColors,borderWidth:0,hoverOffset:4}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>ctx.label+': '+fmt(ctx.raw)+' ('+(total>0?Math.round(ctx.raw/total*100):0)+'%)'}}},cutout:'65%'}
  });
}

function renderCreditSection(){
  const credits=state.accounts.filter(a=>a.type==='credit'&&a.creditLimit>0);
  const el=document.getElementById('d-credit-section');
  if(credits.length===0){el.innerHTML='';return;}
  const totalLimit=credits.reduce((s,a)=>s+(a.creditLimit||0),0);
  const totalUsed=credits.reduce((s,a)=>s+creditUsed(a),0);
  const totalAvail=totalLimit-totalUsed;
  const utilPct=totalLimit>0?Math.round(totalUsed/totalLimit*100):0;
  const utilColor=utilPct>75?'#E24B4A':utilPct>50?'#EF9F27':'#1D9E75';
  el.innerHTML='<div class="section-head">信用卡额度</div><div class="card" style="margin-bottom:.75rem;"><div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-bottom:12px;"><div class="mc"><div class="mc-l">总额度</div><div class="mc-v">'+fmt(totalLimit)+'</div></div><div class="mc"><div class="mc-l">已用</div><div class="mc-v" style="color:'+utilColor+';">'+fmt(totalUsed)+'</div></div><div class="mc"><div class="mc-l">可用</div><div class="mc-v" style="color:var(--color-text-success);">'+fmt(totalAvail)+'</div></div></div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--color-text-secondary);margin-bottom:4px;"><span>综合使用率</span><span style="color:'+utilColor+';font-weight:500;">'+utilPct+'%</span></div><div class="credit-bar-track"><div class="credit-bar-fill" style="width:'+utilPct+'%;background:'+utilColor+';"></div></div>'+(utilPct>30?'<div style="font-size:11px;color:'+utilColor+';margin-top:6px;">建议保持使用率低于 30% 有助于信用评分</div>':'')+(credits.length>1?'<div style="border-top:.5px solid var(--color-border-tertiary);margin-top:10px;padding-top:10px;">'+credits.map(a=>{const used=creditUsed(a);const avail=creditAvail(a);const pct=a.creditLimit>0?Math.round(used/a.creditLimit*100):0;const c=pct>75?'#E24B4A':pct>50?'#EF9F27':'#1D9E75';return'<div style="margin-bottom:8px;"><div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px;"><span style="font-weight:500;">'+a.name+'</span><span style="color:var(--color-text-secondary);">可用 <span style="color:var(--color-text-success);font-weight:500;">'+fmt(avail)+'</span> / '+fmt(a.creditLimit)+'</span></div><div class="credit-bar-track" style="height:5px;"><div class="credit-bar-fill" style="width:'+pct+'%;background:'+c+';"></div></div></div>';}).join('')+'</div>':'')+'</div>';
}

function renderDash(){
  const mTxs=getMonthTxs();
  const spent=mTxs.filter(t=>t.dir==='out').reduce((s,t)=>s+t.amt,0);
  const income=mTxs.filter(t=>t.dir==='in').reduce((s,t)=>s+t.amt,0);
  let net=0;
  state.accounts.forEach(a=>{net+=a.type==='credit'||a.type==='loan'?-(a.type==='credit'?creditUsed(a):debtBalance(a.id)):acctBalance(a.id);});
  document.getElementById('d-net').textContent=fmts(net);
  document.getElementById('d-net').style.color=net>=0?'var(--color-text-success)':'var(--color-text-danger)';
  document.getElementById('d-spent').textContent=fmt(spent);
  document.getElementById('d-income').textContent=fmt(income);

  const debtAccts=state.accounts.filter(a=>a.type==='credit'||a.type==='loan');
  const urgent=debtAccts.filter(a=>a.dueday&&getDaysUntilDue(a.dueday)<=7).sort((a,b)=>getDaysUntilDue(a.dueday)-getDaysUntilDue(b.dueday));
  document.getElementById('d-upcoming').innerHTML=urgent.length>0?'<div class="card" style="border-color:var(--color-border-warning);margin-bottom:.75rem;"><div style="font-size:12px;color:var(--color-text-warning);font-weight:500;margin-bottom:6px;">即将到期还款</div>'+urgent.map(a=>{const days=getDaysUntilDue(a.dueday);const c=acctColor(a.id);return'<div class="row" style="padding:4px 0;"><div style="width:8px;height:8px;border-radius:50%;background:'+c+';flex-shrink:0;"></div><div style="flex:1;font-size:13px;">'+a.name+'</div><span class="urgbadge">'+(days===0?'今天':days+'天后')+'</span><span style="font-size:13px;font-weight:500;color:var(--color-text-danger);">'+fmt(a.minpay||0)+'</span></div>';}).join('')+'</div>':'';

  const pendingSubs=state.subscriptions.filter(s=>s.active!==false&&!isSubAppliedThisMonth(s.id));
  if(pendingSubs.length>0){
    const total=pendingSubs.reduce((s,x)=>s+x.amt,0);
    document.getElementById('d-subs-alert').innerHTML='<div class="card" style="border-color:var(--color-border-info);margin-bottom:.75rem;"><div class="row" style="margin-bottom:6px;"><div style="flex:1;font-size:12px;color:var(--color-text-info);font-weight:500;">'+pendingSubs.length+' 笔固定扣款本月未记录</div><span style="font-size:13px;font-weight:500;color:var(--color-text-info);">'+fmt(total)+'</span></div>'+pendingSubs.map(s=>'<div class="row" style="padding:3px 0;font-size:12px;color:var(--color-text-secondary);"><div style="width:6px;height:6px;border-radius:50%;background:#378ADD;flex-shrink:0;"></div><div style="flex:1;margin-left:6px;">'+s.name+'</div><div>'+fmt(s.amt)+'</div><button onclick="applySingleSub(\''+s.id+'\')" style="font-size:11px;padding:2px 8px;border-radius:4px;border:.5px solid var(--color-border-info);color:var(--color-text-info);background:transparent;cursor:pointer;margin-left:6px;">记录</button></div>').join('')+'</div>';
  } else document.getElementById('d-subs-alert').innerHTML='';

  renderCreditSection();
  renderCatChart();

  const acctEl=document.getElementById('d-accts-list');
  if(state.accounts.length===0){acctEl.innerHTML='<div class="empty">请先在「账户」标签添加账户</div>';}
  else{
    acctEl.innerHTML=state.accounts.map((a,i)=>{
      const isCredit=a.type==='credit';const isLoan=a.type==='loan';const isDebt=isCredit||isLoan;const c=color(i);
      if(isCredit&&a.creditLimit>0){
        const used=creditUsed(a);const avail=creditAvail(a);const pct=Math.round(used/a.creditLimit*100);
        const bc=pct>75?'#E24B4A':pct>50?'#EF9F27':'#1D9E75';
        return'<div class="card" style="margin-bottom:.5rem;"><div class="row" style="margin-bottom:6px;"><div style="width:10px;height:10px;border-radius:50%;background:'+c+';flex-shrink:0;"></div><div style="flex:1;font-weight:500;">'+a.name+'</div><span style="font-size:11px;padding:1px 7px;border-radius:10px;background:'+c+'22;color:'+c+';">信用卡</span></div><div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:8px;"><div><div style="font-size:10px;color:var(--color-text-secondary);">已用</div><div style="font-size:14px;font-weight:500;color:var(--color-text-danger);">'+fmt(used)+'</div></div><div><div style="font-size:10px;color:var(--color-text-secondary);">可用</div><div style="font-size:14px;font-weight:500;color:var(--color-text-success);">'+fmt(avail)+'</div></div><div><div style="font-size:10px;color:var(--color-text-secondary);">总额度</div><div style="font-size:14px;font-weight:500;">'+fmt(a.creditLimit)+'</div></div></div><div class="credit-bar-track"><div class="credit-bar-fill" style="width:'+pct+'%;background:'+bc+';"></div></div><div style="font-size:11px;color:var(--color-text-tertiary);margin-top:3px;">使用率 '+pct+'%</div></div>';
      }
      const bal=isDebt?debtBalance(a.id):acctBalance(a.id);
      return'<div class="card" style="margin-bottom:.5rem;"><div class="row" style="margin-bottom:6px;"><div style="width:10px;height:10px;border-radius:50%;background:'+c+';flex-shrink:0;"></div><div style="flex:1;font-weight:500;">'+a.name+'</div><span style="font-size:11px;padding:1px 7px;border-radius:10px;background:'+c+'22;color:'+c+';">'+TYPE_LABEL[a.type]+'</span></div><div style="font-size:20px;font-weight:500;color:'+(isDebt?'var(--color-text-danger)':'var(--color-text-primary)')+';">'+(isDebt?'-':'')+fmt(bal)+'</div>'+(isLoan&&a.initBal>0?'<div style="height:5px;background:var(--color-background-secondary);border-radius:3px;margin-top:6px;overflow:hidden;"><div style="height:100%;border-radius:3px;background:'+c+';width:'+Math.round(Math.max(0,(1-bal/a.initBal)*100))+'%;"></div></div><div style="font-size:11px;color:var(--color-text-tertiary);margin-top:3px;">已还 '+Math.round(Math.max(0,(1-bal/a.initBal)*100))+'%</div>':'')+'</div>';
    }).join('');
  }

  const recent=[...state.transactions.map(t=>({...t,kind:'tx'})),...state.transfers.map(t=>({...t,kind:'tf'}))]
    .sort((a,b)=>new Date(b.date)-new Date(a.date)).slice(0,6);
  const recEl=document.getElementById('d-recent');
  if(recent.length===0){recEl.innerHTML='<div class="empty">暂无记录</div>';return;}
  recEl.innerHTML=recent.map(r=>{
    if(r.kind==='tx'){const c=acctColor(r.acctId);
      return'<div class="tx-item"><div class="tx-dot" style="background:'+c+';"></div><div class="tx-name"><div class="tx-main">'+( r.note||r.cat)+(r.auto?'<span style="font-size:10px;margin-left:5px;padding:1px 5px;border-radius:8px;background:var(--color-background-info);color:var(--color-text-info);">自动</span>':'')+'</div><div class="tx-sub">'+r.cat+'</div></div><div class="tx-amt" style="color:'+(r.dir==='in'?'var(--color-text-success)':'var(--color-text-danger)')+';">'+(r.dir==='in'?'+':'-')+fmt(r.amt)+'</div></div>';
    }
    const fn=state.accounts.find(a=>a.id===r.fromId)?.name||'?';
    const tn=state.accounts.find(a=>a.id===r.toId)?.name||'?';
    return'<div class="tx-item"><div class="tx-dot" style="background:#7F77DD;"></div><div class="tx-name"><div class="tx-main">'+(r.note||'转账')+'</div><div class="tx-sub">'+fn+' → '+tn+'</div></div><div class="tx-amt" style="color:var(--color-text-secondary);">'+fmt(r.amt)+'</div></div>';
  }).join('');
}

function renderTx(){
  const mTxs=getMonthTxs().sort((a,b)=>new Date(b.date)-new Date(a.date));
  const el=document.getElementById('tx-list-el');
  if(mTxs.length===0){el.innerHTML='<div class="empty">本月还没有记录</div>';return;}
  el.innerHTML=mTxs.map(t=>{const c=acctColor(t.acctId);const an=state.accounts.find(a=>a.id===t.acctId)?.name||'?';
    return'<div class="tx-item"><div class="tx-dot" style="background:'+c+';"></div><div class="tx-name"><div class="tx-main">'+(t.note||t.cat)+(t.auto?'<span style="font-size:10px;margin-left:5px;padding:1px 5px;border-radius:8px;background:var(--color-background-info);color:var(--color-text-info);">自动</span>':'')+'</div><div class="tx-sub">'+t.cat+' · '+an+'</div></div><div class="tx-amt" style="color:'+(t.dir==='in'?'var(--color-text-success)':'var(--color-text-danger)')+';">'+(t.dir==='in'?'+':'-')+fmt(t.amt)+'</div><button class="del-btn" onclick="delTx(\''+t.id+'\')">✕</button></div>';
  }).join('');
}

function renderTransfers(){
  const el=document.getElementById('tr-list-el');
  const sorted=[...state.transfers].sort((a,b)=>new Date(b.date)-new Date(a.date));
  if(sorted.length===0){el.innerHTML='<div class="empty">还没有转账记录</div>';return;}
  el.innerHTML=sorted.map(t=>{const fn=state.accounts.find(a=>a.id===t.fromId)?.name||'?';const tn=state.accounts.find(a=>a.id===t.toId)?.name||'?';
    return'<div class="tx-item"><div class="tx-dot" style="background:#7F77DD;"></div><div class="tx-name"><div class="tx-main">'+(t.note||'转账')+'</div><div class="tx-sub">'+fn+' → '+tn+'</div></div><div class="tx-amt">'+fmt(t.amt)+'</div><button class="del-btn" onclick="delTransfer(\''+t.id+'\')">✕</button></div>';
  }).join('');
}

function renderSubs(){
  const summEl=document.getElementById('subs-summary');
  const el=document.getElementById('subs-list-el');
  const active=state.subscriptions.filter(s=>s.active!==false);
  const totalMonthly=active.reduce((s,x)=>s+x.amt,0);
  summEl.innerHTML=active.length>0?'<div class="metrics" style="grid-template-columns:repeat(2,minmax(0,1fr));"><div class="mc"><div class="mc-l">月固定支出</div><div class="mc-v" style="color:var(--color-text-danger);">'+fmt(totalMonthly)+'</div></div><div class="mc"><div class="mc-l">年固定支出</div><div class="mc-v" style="color:var(--color-text-warning);">'+fmt(totalMonthly*12)+'</div></div></div>':'';
  if(state.subscriptions.length===0){el.innerHTML='<div class="empty">还没有固定扣款项目</div>';return;}
  el.innerHTML=[...state.subscriptions].sort((a,b)=>a.day-b.day).map(s=>{
    const applied=isSubAppliedThisMonth(s.id);const days=getDaysUntilDue(s.day);const acctName=state.accounts.find(a=>a.id===s.acctId)?.name||'?';const isActive=s.active!==false;
    return'<div class="sub-card" style="opacity:'+(isActive?1:0.5)+';"><div class="row" style="margin-bottom:'+(isActive&&!applied?'8':'0')+'px;"><div style="flex:1;"><div style="font-weight:500;">'+s.name+'</div><div style="font-size:11px;color:var(--color-text-secondary);margin-top:2px;">'+s.cat+' · '+acctName+' · 每月'+s.day+'号</div></div><div style="text-align:right;margin-right:8px;"><div style="font-weight:500;color:var(--color-text-danger);">'+fmt(s.amt)+'</div><div style="font-size:10px;color:var(--color-text-tertiary);">'+(applied?'✓ 已记录':isActive?days===0?'今天':days+'天后':'已暂停')+'</div></div><button onclick="toggleSub(\''+s.id+'\')" style="font-size:11px;padding:3px 8px;border-radius:4px;border:.5px solid var(--color-border-secondary);background:transparent;color:var(--color-text-secondary);cursor:pointer;">'+(isActive?'暂停':'恢复')+'</button><button class="del-btn" onclick="delSub(\''+s.id+'\')">✕</button></div>'+(isActive&&!applied?'<button onclick="applySingleSub(\''+s.id+'\')" style="width:100%;font-size:12px;padding:5px;border-radius:6px;border:.5px solid var(--color-border-info);color:var(--color-text-info);background:var(--color-background-info);cursor:pointer;">记录本月扣款 '+fmt(s.amt)+'</button>':'')+'</div>';
  }).join('');
}

function renderDebt(){
  const debtAccts=state.accounts.filter(a=>a.type==='credit'||a.type==='loan');
  document.getElementById('dbt-total').textContent=fmt(debtAccts.reduce((s,a)=>s+(a.type==='credit'?creditUsed(a):debtBalance(a.id)),0));
  document.getElementById('dbt-due').textContent=fmt(debtAccts.reduce((s,a)=>s+(a.minpay||0),0));
  const el=document.getElementById('dbt-list-el');
  if(debtAccts.length===0){el.innerHTML='<div class="empty">没有信用卡或贷款账户</div>';return;}
  el.innerHTML=[...debtAccts].sort((a,b)=>getDaysUntilDue(a.dueday||28)-getDaysUntilDue(b.dueday||28)).map(a=>{
    const isCredit=a.type==='credit';const bal=isCredit?creditUsed(a):debtBalance(a.id);const c=acctColor(state.accounts.indexOf(a));
    const days=a.dueday?getDaysUntilDue(a.dueday):null;
    const badge=days!==null?(days<=3?'<span class="urgbadge">'+(days===0?'今天':days+'天后')+'</span>':days<=7?'<span class="warnbadge">'+days+'天后</span>':'<span class="okbadge">'+days+'天后</span>'):'';
    return'<div class="card" style="margin-bottom:.5rem;"><div class="row" style="margin-bottom:8px;"><div style="width:9px;height:9px;border-radius:50%;background:'+c+';flex-shrink:0;"></div><div style="flex:1;font-weight:500;">'+a.name+'</div>'+badge+'</div><div class="row" style="margin-bottom:4px;"><span style="color:var(--color-text-secondary);font-size:13px;flex:1;">'+(isCredit?'已用额度':'余额')+'</span><span style="font-weight:500;color:var(--color-text-danger);">'+fmt(bal)+'</span></div>'+(isCredit&&a.creditLimit?'<div class="row" style="margin-bottom:4px;"><span style="color:var(--color-text-secondary);font-size:13px;flex:1;">可用额度</span><span style="font-weight:500;color:var(--color-text-success);">'+fmt(creditAvail(a))+'</span></div>':'')+'<div class="row" style="margin-bottom:4px;"><span style="color:var(--color-text-secondary);font-size:13px;flex:1;">最低还款</span><span style="font-weight:500;">'+fmt(a.minpay||0)+'</span></div><div class="row"><span style="color:var(--color-text-secondary);font-size:13px;flex:1;">年利率</span><span style="font-weight:500;">'+(a.rate||0)+'%</span></div></div>';
  }).join('');
  renderStrategy();
}

function renderStrategy(){
  const el=document.getElementById('strategy-list');if(!el)return;
  const debtAccts=state.accounts.filter(a=>a.type==='credit'||a.type==='loan').map(a=>({...a,curBal:a.type==='credit'?creditUsed(a):debtBalance(a.id)}));
  if(debtAccts.length===0){el.innerHTML='';return;}
  const extra=parseFloat(document.getElementById('extra-pay')?.value)||0;
  let ranked=[...debtAccts];
  if(stratMode==='avalanche')ranked.sort((a,b)=>b.rate-a.rate);else ranked.sort((a,b)=>a.curBal-b.curBal);
  const rc=['#E24B4A','#EF9F27','#378ADD'];
  el.innerHTML=ranked.map((a,i)=>{const c=rc[i]||'#888780';const totalPay=(a.minpay||0)+(i===0?extra:0);const monthInt=Math.round(a.curBal*(a.rate||0)/100/12*100)/100;
    return'<div class="strat-card"><div class="rank-circle" style="background:'+c+';color:#fff;">'+(i+1)+'</div><div style="flex:1;min-width:0;"><div style="font-weight:500;margin-bottom:2px;">'+a.name+'</div><div style="font-size:11px;color:var(--color-text-secondary);">'+(a.rate||0)+'% APR · 欠 '+fmt(a.curBal)+' · 月利息约 '+fmt(monthInt)+'</div></div><div style="text-align:right;flex-shrink:0;"><div style="font-weight:500;color:'+(i===0?'#E24B4A':'var(--color-text-primary)')+';">'+fmt(totalPay)+'</div><div style="font-size:11px;color:var(--color-text-tertiary);">本月还</div></div></div>';
  }).join('');
}

function renderAccts(){
  const el=document.getElementById('accts-list-el');
  if(state.accounts.length===0){el.innerHTML='<div class="empty">还没有账户</div>';return;}
  el.innerHTML=state.accounts.map((a,i)=>{
    const isDebt=a.type==='credit'||a.type==='loan';const isCredit=a.type==='credit';const c=color(i);
    const balDisplay=isCredit?(a.creditLimit?'已用 '+fmt(creditUsed(a))+' / '+fmt(a.creditLimit):fmt(creditUsed(a))):isDebt?fmt(debtBalance(a.id)):fmt(acctBalance(a.id));
    return'<div class="card" style="margin-bottom:.5rem;"><div class="row"><div style="width:9px;height:9px;border-radius:50%;background:'+c+';flex-shrink:0;"></div><div style="flex:1;font-weight:500;">'+a.name+'</div><span style="font-size:11px;padding:1px 7px;border-radius:10px;background:'+c+'22;color:'+c+';">'+TYPE_LABEL[a.type]+'</span><button class="del-btn" onclick="delAcct(\''+a.id+'\')">删除</button></div><div style="margin-top:6px;font-size:15px;font-weight:500;color:'+(isDebt?'var(--color-text-danger)':'var(--color-text-primary)')+';">'+(isDebt&&!isCredit?'-':'')+balDisplay+'</div>'+(isCredit&&a.creditLimit>0?'<div style="font-size:13px;color:var(--color-text-success);margin-top:2px;">可用 '+fmt(creditAvail(a))+'</div>':'')+'</div>';
  }).join('');
}

function addSub(){
  const name=document.getElementById('sb-name').value.trim();const amt=parseFloat(document.getElementById('sb-amt').value)||0;
  const day=parseInt(document.getElementById('sb-day').value)||1;const acctId=document.getElementById('sb-acct').value;const cat=document.getElementById('sb-cat').value;
  if(!name||!amt||!acctId)return;
  state.subscriptions.push({id:'s'+Date.now(),name,amt,day,acctId,cat,active:true});save();
  ['sb-name','sb-amt','sb-day'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});updateAll();
}
function toggleSub(id){const s=state.subscriptions.find(x=>x.id===id);if(s){s.active=s.active===false?true:false;save();updateAll();}}
function delSub(id){state.subscriptions=state.subscriptions.filter(s=>s.id!==id);save();updateAll();}

function addAcct(){
  const name=document.getElementById('ac-name').value.trim();const type=document.getElementById('ac-type').value;
  const bal=parseFloat(document.getElementById('ac-bal').value)||0;
  const isCredit=type==='credit';const isLoan=type==='loan';
  const limit=isCredit?(parseFloat(document.getElementById('ac-limit').value)||0):0;
  const rate=isCredit?(parseFloat(document.getElementById('ac-rate').value)||0):(isLoan?(parseFloat(document.getElementById('ac-loan-rate').value)||0):0);
  const minpay=isCredit?(parseFloat(document.getElementById('ac-minpay').value)||0):(isLoan?(parseFloat(document.getElementById('ac-loan-minpay').value)||0):0);
  const dueday=isCredit?(parseInt(document.getElementById('ac-dueday').value)||0):(isLoan?(parseInt(document.getElementById('ac-loan-dueday').value)||0):0);
  if(!name)return;
  state.accounts.push({id:'a'+Date.now(),name,type,initBal:bal,creditLimit:limit,rate,minpay,dueday});save();
  ['ac-name','ac-bal','ac-limit','ac-rate','ac-minpay','ac-dueday','ac-loan-rate','ac-loan-minpay','ac-loan-dueday'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  updateAll();
}
function delAcct(id){
  state.accounts=state.accounts.filter(a=>a.id!==id);
  state.transactions=state.transactions.filter(t=>t.acctId!==id);
  state.transfers=state.transfers.filter(t=>t.fromId!==id&&t.toId!==id);
  state.subscriptions=state.subscriptions.filter(s=>s.acctId!==id);
  save();updateAll();
}
function addTx(){
  const amt=parseFloat(document.getElementById('tx-amt').value)||0;const acctId=document.getElementById('tx-acct').value;
  const dir=document.getElementById('tx-dir').value;const cat=document.getElementById('tx-cat').value;const note=document.getElementById('tx-note').value.trim();
  if(!amt||!acctId)return;
  state.transactions.push({id:'t'+Date.now(),amt,acctId,dir,cat,note,date:new Date().toISOString()});
  save();document.getElementById('tx-amt').value='';document.getElementById('tx-note').value='';updateAll();
}
function delTx(id){state.transactions=state.transactions.filter(t=>t.id!==id);save();updateAll();}
function doTransfer(){
  const amt=parseFloat(document.getElementById('tr-amt').value)||0;const fromId=document.getElementById('tr-from').value;
  const toId=document.getElementById('tr-to').value;const note=document.getElementById('tr-note').value.trim();
  if(!amt||!fromId||!toId||fromId===toId)return;
  state.transfers.push({id:'r'+Date.now(),amt,fromId,toId,note,date:new Date().toISOString()});
  save();document.getElementById('tr-amt').value='';document.getElementById('tr-note').value='';updateAll();
}
function delTransfer(id){state.transfers=state.transfers.filter(t=>t.id!==id);save();updateAll();}

function setStrat(m){
  stratMode=m;
  document.getElementById('s-av').style.border=m==='avalanche'?'2px solid var(--color-border-info)':'.5px solid var(--color-border-tertiary)';
  document.getElementById('s-av').querySelector('div').style.color=m==='avalanche'?'var(--color-text-info)':'var(--color-text-primary)';
  document.getElementById('s-sb').style.border=m==='snowball'?'2px solid var(--color-border-info)':'.5px solid var(--color-border-tertiary)';
  document.getElementById('s-sb').querySelector('div').style.color=m==='snowball'?'var(--color-text-info)':'var(--color-text-primary)';
  renderStrategy();
}

document.getElementById('ac-type').addEventListener('change',function(){
  const isCredit=this.value==='credit';const isLoan=this.value==='loan';
  document.getElementById('ac-credit-fields').style.display=isCredit?'block':'none';
  document.getElementById('ac-loan-fields').style.display=isLoan?'block':'none';
  document.getElementById('ac-bal-label').textContent=isCredit?'当前已用额度（$）':isLoan?'当前欠款（$）':'当前余额（$）';
});

function sw(tab){
  currentTab=tab;
  ['dash','tx','transfer','subs','debt','accts'].forEach(t=>{
    document.getElementById('panel-'+t).style.display=t===tab?'block':'none';
    document.getElementById('tab-'+t).className='tab'+(t===tab?' active':'');
  });
  populateSelects();
  if(tab==='dash')renderDash();
  else if(tab==='tx')renderTx();
  else if(tab==='transfer')renderTransfers();
  else if(tab==='subs')renderSubs();
  else if(tab==='debt')renderDebt();
  else if(tab==='accts')renderAccts();
}
function updateAll(){
  populateSelects();
  if(currentTab==='dash')renderDash();
  else if(currentTab==='tx')renderTx();
  else if(currentTab==='transfer')renderTransfers();
  else if(currentTab==='subs')renderSubs();
  else if(currentTab==='debt')renderDebt();
  else if(currentTab==='accts')renderAccts();
  if(currentTab!=='dash')renderDash();
}
populateSelects();renderDash();

function exportData(){
  const now=new Date();
  const stamp=now.getFullYear()+'-'+(now.getMonth()+1)+'-'+now.getDate();
  const payload=JSON.stringify({version:'finhub_v4',exportedAt:now.toISOString(),data:state},null,2);
  const blob=new Blob([payload],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;a.download='finance_hub_backup_'+stamp+'.json';
  document.body.appendChild(a);a.click();
  document.body.removeChild(a);URL.revokeObjectURL(url);
}

function importData(e){
  const file=e.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=function(ev){
    const statusEl=document.getElementById('import-status');
    try{
      const parsed=JSON.parse(ev.target.result);
      const incoming=parsed.data||parsed;
      if(!incoming.accounts||!incoming.transactions){
        statusEl.textContent='文件格式不对，请选择正确的备份文件。';
        statusEl.style.color='var(--color-text-danger)';return;
      }
      const counts={
        accounts:(incoming.accounts||[]).length,
        transactions:(incoming.transactions||[]).length,
        transfers:(incoming.transfers||[]).length,
        subscriptions:(incoming.subscriptions||[]).length
      };
      if(!confirm('将导入：'+counts.accounts+' 个账户、'+counts.transactions+' 条记录、'+counts.transfers+' 条转账、'+counts.subscriptions+' 个固定扣款。\n\n这会覆盖当前所有数据，确认继续？'))return;
      state={
        accounts:incoming.accounts||[],
        transactions:incoming.transactions||[],
        transfers:incoming.transfers||[],
        subscriptions:incoming.subscriptions||[]
      };
      save();updateAll();
      statusEl.textContent='导入成功！共 '+counts.accounts+' 个账户，'+counts.transactions+' 条记录。';
      statusEl.style.color='var(--color-text-success)';
    }catch(err){
      const statusEl=document.getElementById('import-status');
      statusEl.textContent='导入失败，文件损坏或格式不正确。';
      statusEl.style.color='var(--color-text-danger)';
    }
    e.target.value='';
  };
  reader.readAsText(file);
}
</script>
</body>
</html>
